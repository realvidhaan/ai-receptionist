# Copy to .env and fill in. .env is gitignored — never commit real secrets.
GEMINI_KEY=your-google-ai-studio-key
SA_KEY_PATH=/absolute/path/to/service-account.json
SHEET_ID=your-google-sheet-id
CALENDAR_ID=you@gmail.com
SMTP_USER=sender@gmail.com
SMTP_PW=gmail app password
OWNER_EMAIL=owner@gmail.com
TZ=America/Los_Angeles
BUSINESS=Bay Area Comfort HVAC
CITY=San Jose
MAPS_KEY=your-google-maps-places-key
# multi-tenant provisioning (Stage 2 / n8n):
PROVISION_SECRET=a-long-random-string-shared-with-n8n
PUBLIC_BASE=https://your-tunnel.trycloudflare.com
